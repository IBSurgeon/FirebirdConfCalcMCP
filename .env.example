# Credentials for the Firebird Configuration Calculator API
# Register at https://cc.ib-aid.com/ to get your API password
#
# Usage: copy this file to password_api.txt and fill in your credentials.
# NEVER commit password_api.txt to version control!
#
# CC_EMAIL=your@email.com
# CC_PASSWORD=your_api_password

# Port for the MCP HTTP server (Streamable HTTP via supergateway)
PORT=8000

# Enable/disable update check on startup
CC_UPDATE_CHECK=enabled
